rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===== ADMIN AUTH =====
    function isAdmin() {
      // Single-admin beta: any signed-in Firebase Auth user is treated as Admin.
      // Later this can be replaced with custom claims.
      return request.auth != null;
    }

    // ===== DEVICE PAIRING HELPERS =====
    function pairedDeviceDoc(deviceId) {
      return /databases/$(database)/documents/pairedDevices/$(deviceId);
    }

    function hasDeviceMetadata() {
      return request.resource.data.deviceMetadata is map
        && request.resource.data.deviceMetadata.deviceId is string
        && request.resource.data.deviceMetadata.deviceToken is string
        && request.resource.data.deviceMetadata.deviceType is string;
    }

    function isKnownPairedDevice() {
      return hasDeviceMetadata()
        && exists(pairedDeviceDoc(request.resource.data.deviceMetadata.deviceId))
        && get(pairedDeviceDoc(request.resource.data.deviceMetadata.deviceId)).data.deviceToken
          == request.resource.data.deviceMetadata.deviceToken;
    }

    function isPairedPassengerTablet() {
      return isKnownPairedDevice()
        && get(pairedDeviceDoc(request.resource.data.deviceMetadata.deviceId)).data.deviceType
          == "passengerTablet";
    }

    function isPairedDriverConsoleFromUpdate() {
      return request.resource.data.updatedByDevice is map
        && request.resource.data.updatedByDevice.deviceId is string
        && request.resource.data.updatedByDevice.deviceToken is string
        && exists(pairedDeviceDoc(request.resource.data.updatedByDevice.deviceId))
        && get(pairedDeviceDoc(request.resource.data.updatedByDevice.deviceId)).data.deviceToken
          == request.resource.data.updatedByDevice.deviceToken
        && get(pairedDeviceDoc(request.resource.data.updatedByDevice.deviceId)).data.deviceType
          == "driverConsole";
    }

    // ===== GUESTBOOK HELPERS =====
    function hasOnlyAllowedGuestbookCreateFields() {
      return request.resource.data.keys().hasOnly([
        "id",
        "name",
        "city",
        "message",
        "approved",
        "createdAtMs",
        "createdAt",
        "updatedAt"
      ]);
    }

    function isPendingGuestbookCreate() {
      return hasOnlyAllowedGuestbookCreateFields()
        && request.resource.data.approved == false
        && request.resource.data.name is string
        && request.resource.data.message is string
        && request.resource.data.city is string
        && request.resource.data.createdAtMs is number
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 80
        && request.resource.data.city.size() <= 120
        && request.resource.data.message.size() > 0
        && request.resource.data.message.size() <= 1000;
    }

    // ===== ADMIN CONFIG =====
    match /adminConfig/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ===== ADS / DEALS =====
    match /ads/{adId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ===== GUESTBOOK ENTRIES =====
    match /guestbookEntries/{entryId} {
      allow read: if true;
      allow create: if isPendingGuestbookCreate();
      allow update, delete: if isAdmin();
    }

    // ===== RIDE SESSIONS / REQUESTS =====
    match /rideSessions/{sessionId} {
      allow read: if true;

      // Passenger language/session sync remains open for beta.
      allow create, update: if true;

      match /requests/{requestId} {
        allow read: if true;

        // For this beta, request creation remains open.
        // Later this can be changed to: allow create: if isPairedPassengerTablet();
        allow create: if true;

        // Request status updates can be Firebase Admin or a paired Driver Console.
        // App writes updatedByDevice.deviceId/deviceToken/deviceType on status updates.
        allow update: if isAdmin() || isPairedDriverConsoleFromUpdate();

        allow delete: if isAdmin();
      }
    }

    // ===== DEVICE PAIRING CODES =====
    match /pairingCodes/{code} {
      allow read: if true;

      allow create: if request.resource.data.status == "pending"
        && request.resource.data.deviceId is string
        && request.resource.data.deviceToken is string
        && request.resource.data.deviceName is string
        && request.resource.data.deviceName.size() > 0
        && request.resource.data.deviceName.size() <= 60
        && request.resource.data.deviceType in ["passengerTablet", "driverConsole"];

      allow update, delete: if isAdmin();
    }

    // ===== PAIRED DEVICES =====
    match /pairedDevices/{deviceId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ===== LEGACY GUESTBOOK CONTAINER =====
    match /guestbook/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ===== DEFAULT DENY =====
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
