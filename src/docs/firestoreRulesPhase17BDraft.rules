rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===== PHASE 17B RULES DRAFT =====
    // Requires Firebase Auth for protected Admin writes.
    // Passenger tablet remains no-login for read access, requests, and pending guestbook submissions.

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // For this single-admin beta, any signed-in Firebase Auth user is treated as Admin.
      // Before multi-admin/public release, replace this with custom claims:
      // return request.auth != null && request.auth.token.admin == true;
      return request.auth != null;
    }

    function hasOnlyAllowedGuestbookCreateFields() {
      return request.resource.data.keys().hasOnly([
        "id",
        "name",
        "city",
        "message",
        "approved",
        "createdAtMs",
        "createdAt",
        "updatedAt"
      ]);
    }

    function isPendingGuestbookCreate() {
      return hasOnlyAllowedGuestbookCreateFields()
        && request.resource.data.approved == false
        && request.resource.data.name is string
        && request.resource.data.message is string
        && request.resource.data.city is string
        && request.resource.data.createdAtMs is number
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 80
        && request.resource.data.city.size() <= 120
        && request.resource.data.message.size() > 0
        && request.resource.data.message.size() <= 1000;
    }

    // ===== RIDE SESSION SYNC =====
    match /rideSessions/{sessionId} {
      allow read: if true;

      // Passenger language sync stays public for beta.
      allow create, update: if true;

      match /requests/{requestId} {
        allow read: if true;

        // Passenger creates ride requests.
        // TODO: tighten field validation after request object shape is finalized.
        allow create: if true;

        // Driver console updates request status. Require Firebase Admin.
        allow update, delete: if isAdmin();
      }
    }

    // ===== ADMIN CONFIG DOCUMENTS =====
    match /adminConfig/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ===== ADS / LOCAL DEALS =====
    match /ads/{adId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ===== GUESTBOOK ENTRIES =====
    match /guestbookEntries/{entryId} {
      allow read: if true;

      // Passenger may create pending entries only.
      allow create: if isPendingGuestbookCreate();

      // Only Admin can approve, edit, or delete.
      allow update, delete: if isAdmin();
    }

    // ===== LEGACY GUESTBOOK CONTAINER =====
    match /guestbook/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ===== DEVICE PAIRING =====
    match /pairingCodes/{code} {
      // A device creates a pending code and listens for approval.
      allow read: if true;
      allow create: if request.resource.data.status == "pending";
      allow update, delete: if isAdmin();
    }

    match /pairedDevices/{deviceId} {
      // Paired device records can be read by the app.
      allow read: if true;

      // Admin approves/removes paired devices.
      allow create, update, delete: if isAdmin();
    }

    // ===== DEFAULT DENY =====
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
